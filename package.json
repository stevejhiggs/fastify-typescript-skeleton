{
  "name": "fastify-example",
  "version": "1.0.0",
  "description": "",
  "main": "lib/listener.js",
  "type": "module",
  "scripts": {
    "start": "bun ./index.ts | pino-pretty",
    "start:production": "bun ./index.ts",
    "build": "bun -b tsc -p tsconfig.json",
    "test": "LOG_LEVEL=warn bun test",
    "test:ci": "bun run test -- --coverage",
    "typecheck": "bun -b tsc --noEmit",
    "format": "bun -b prettier --write '**/*.{js,jsx,ts,tsx,css,html,yaml,json,md}'",
    "lint:ci": "bun -b biome check ./src",
    "lint": "bun -b run lint:ci --apply",
    "prepare": "bun -b husky install && rm -rf .git/hooks && ln -s ../.husky .git/hooks",
    "pre-commit": "bun -b lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevejhiggs/fastify-example.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/stevejhiggs/fastify-example/issues"
  },
  "homepage": "https://github.com/stevejhiggs/fastify-example#readme",
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/type-provider-typebox": "^4.0.0",
    "@sinclair/typebox": "0.32.29",
    "fastify": "^4.27.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@types/bun": "^1.1.1",
    "globals": "^15.2.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "pino-pretty": "^11.0.0",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "bun -b biome check --apply --no-errors-on-unmatched"
    ]
  }
}
